function gaugeSvg(pct, color){
  const r=30, c=2*Math.PI*r, off = c - (Math.min(pct,100)/100)*c;
  return `<div class="gauge-wrap"><svg width="74" height="74" viewBox="0 0 74 74">
    <circle cx="37" cy="37" r="${r}" fill="none" stroke="var(--border)" stroke-width="7"/>
    <circle cx="37" cy="37" r="${r}" fill="none" stroke="${color}" stroke-width="7" stroke-linecap="round"
      stroke-dasharray="${c}" stroke-dashoffset="${off}" style="transition:stroke-dashoffset 1s ease"/>
  </svg><div class="gauge-val">${Math.round(pct)}%</div></div>`;
}
