/* ================= GLOBAL SEARCH ================= */
function globalSearchHandler(q){
  const box = document.getElementById('globalSearchResults');
  if(!q || q.length<2){ if(box) box.style.display='none'; return; }
  const db = loadDB(); q = q.toLowerCase();
  const results = [
    ...db.customers.filter(c=>c.name.toLowerCase().includes(q)).map(c=>({label:c.name, sub:'Customer', page:'customers'})),
    ...db.vehicles.filter(v=>(v.plate+v.make+v.model).toLowerCase().includes(q)).map(v=>({label:`${v.make} ${v.model} (${v.plate})`, sub:'Vehicle', page:'vehicles'})),
    ...db.invoices.filter(i=>('inv'+i.id).toLowerCase().includes(q)).map(i=>({label:'INV-'+i.id.slice(-4).toUpperCase(), sub:'Invoice', page:'invoices'})),
  ].slice(0,8);
  if(!box){
    const nb = document.createElement('div'); nb.id='globalSearchResults';
    nb.style.cssText='position:absolute;top:110%;left:0;right:0;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;z-index:2000;max-height:260px;overflow:auto;box-shadow:0 12px 30px -10px rgba(0,0,0,.5)';
    document.querySelector('.search-box').appendChild(nb);
  }
  const finalBox = document.getElementById('globalSearchResults');
  finalBox.style.display = results.length? 'block':'none';
  finalBox.innerHTML = results.map(r=>`<div style="padding:.5rem .8rem;font-size:.82rem;cursor:pointer;border-bottom:1px solid var(--border-soft)" onmousedown="showPage('${r.page}')">${esc(r.label)} <span style="color:var(--text-faint);font-size:.7rem">· ${r.sub}</span></div>`).join('');
}
document.addEventListener('click', (e)=>{ if(!e.target.closest('.search-box')){ const b=document.getElementById('globalSearchResults'); if(b) b.style.display='none'; } });

