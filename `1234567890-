function quickFill(email,pass){ document.getElementById('loginEmail').value=email; document.getElementById('loginPassword').value=pass; }

function doLogin(){
  const email = document.getElementById('loginEmail').value.trim().toLowerCase();
  const pass = document.getElementById('loginPassword').value;
  const db = loadDB();
  const user = db.users.find(u=>u.email.toLowerCase()===email && u.password===pass);
  if(!user){ showFieldError('Invalid email or password.'); return; }
  currentUser = user;
  sessionStorage.setItem('acp_session', JSON.stringify(user));
  enterApp();
}
function doRegister(){
  const name = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim().toLowerCase();
  const p1 = document.getElementById('regPassword').value;
  const p2 = document.getElementById('regPassword2').value;
  if(!name || !email || !p1){ showFieldError('Please fill all fields.'); return; }
  if(p1 !== p2){ showFieldError('Passwords do not match.'); return; }
  const db = loadDB();
  if(db.users.some(u=>u.email.toLowerCase()===email)){ showFieldError('An account with this email already exists.'); return; }
  const user = {id:uid('u'), name, email, password:p1, role:'receptionist'};
  db.users.push(user); saveDB(db);
  currentUser = user;
  sessionStorage.setItem('acp_session', JSON.stringify(user));
  enterApp();
}
function doForgot(){
  const email = document.getElementById('forgotEmail').value.trim();
  if(!email){ showFieldError('Enter your email.'); return; }
  document.getElementById('authFormArea').innerHTML = `<div class="text-center py-3"><i class="bi bi-envelope-check" style="font-size:2rem;color:var(--green)"></i><p class="mt-3" style="font-size:.85rem;color:var(--text-dim)">${t('reset_sent')}</p><button class="btn btn-outline-brand w-100 mt-2" onclick="renderAuthForm('login')">${t('back_to_login')}</button></div>`;
}
function showFieldError(msg){
  let el = document.getElementById('authErrBox');
  if(!el){
    el = document.createElement('div');
    el.id='authErrBox';
    el.style.cssText='background:rgba(232,53,47,.12);border:1px solid var(--red);color:var(--red);font-size:.78rem;padding:.5rem .7rem;border-radius:8px;margin-bottom:.8rem';
    document.getElementById('authFormArea').prepend(el);
  }
  el.textContent = msg;
}

function logout(){
  sessionStorage.removeItem('acp_session');
