/* ---------------- Small helpers ---------------- */
function fmtMoney(n){ const db=loadDB(); return (db.settings.currency||'€') + Number(n||0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtDate(d){ if(!d) return '—'; const dt = new Date(d); return dt.toLocaleDateString(undefined,{year:'numeric',month:'short',day:'numeric'}); }
function getCustomer(id){ return loadDB().customers.find(c=>c.id===id); }
function getVehicle(id){ return loadDB().vehicles.find(v=>v.id===id); }
function custName(id){ const c=getCustomer(id); return c? c.name : '—'; }
function vehicleLabel(id){ const v=getVehicle(id); return v? `${v.make} ${v.model} · ${v.plate}` : '—'; }
function esc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }
function woTotal(w){ return Number(w.laborCost||0) + Number(w.partsCost||0); }
function statusPill(status){
  const map = {
    completed:['s-green','Completed'], in_progress:['s-blue','In Progress'], pending:['s-amber','Pending'],
    confirmed:['s-green','Confirmed'], cancelled:['s-red','Cancelled'], paid:['s-green','Paid'], unpaid:['s-red','Unpaid'],
    ordered:['s-blue','Ordered'], received:['s-green','Received'],
  };
  const m = map[status] || ['s-grey', status];
  return `<span class="status-pill dot ${m[0]}">${m[1]}</span>`;
}

