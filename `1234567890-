  const db = loadDB(); const inv = db.invoices.find(i=>i.id===id);
  const amt = invoiceAmounts(inv);
  const wo = db.workorders.find(w=>w.id===inv.workOrderId) || {};
  const cust = getCustomer(inv.customerId) || {};
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF();
  try{ doc.addImage('data:image/png;base64,','PNG',15,12,18,18); }catch(e){}
  doc.setFontSize(16); doc.setTextColor(232,53,47); doc.text('AUTO CHECK PRO AL', 38, 20);
  doc.setFontSize(9); doc.setTextColor(100); doc.text(db.settings.address, 38, 26);
  doc.setFontSize(14); doc.setTextColor(20); doc.text(`INVOICE INV-${inv.id.slice(-4).toUpperCase()}`, 150, 20);
  doc.setFontSize(10); doc.text(`Date: ${fmtDate(inv.date)}`, 150, 26);
  doc.setDrawColor(232,53,47); doc.line(15,34,195,34);
  doc.setFontSize(11); doc.text(`Bill To: ${cust.name||''}`, 15, 44);
  doc.setFontSize(9); doc.text(`${cust.phone||''}  ${cust.email||''}`, 15, 50);
  doc.setFontSize(10);
  doc.text('Description', 15, 65); doc.text('Amount', 175, 65);
  doc.line(15,68,195,68);
  doc.text(`${(wo.description||'Service')} — Labor`, 15, 76); doc.text(fmtMoney(wo.laborCost), 175, 76);
  doc.text(`${(wo.description||'Service')} — Parts`, 15, 84); doc.text(fmtMoney(wo.partsCost), 175, 84);
  doc.line(15,92,195,92);
  doc.text(`Subtotal: ${fmtMoney(amt.subtotal)}`, 140, 100);
  doc.text(`VAT (${inv.vatRate}%): ${fmtMoney(amt.vat)}`, 140, 107);
  doc.setFontSize(13); doc.text(`Total: ${fmtMoney(amt.total)}`, 140, 116);
  doc.setFontSize(9); doc.setTextColor(150); doc.text('Kujdesemi për makinën tënde.', 15, 280);
  doc.save(`Invoice-${inv.id.slice(-4).toUpperCase()}.pdf`);
  showToast('Invoice PDF downloaded.');
}

