<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auto Check Pro AL — Workshop Management</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Rajdhani:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
:root{
  --bg:#0a0a0b; --bg-elev:#131315; --bg-card:#18181b; --bg-card-hov:#1e1e22;
  --border:#28282c; --border-soft:#1e1e22;
  --red:#e8352f; --red-dim:#b8241f; --red-glow:rgba(232,53,47,.35);
  --amber:#f2a93c; --cream:#f3e3c1;
  --text:#f2f2f3; --text-dim:#9a9aa0; --text-faint:#606066;
  --white:#ffffff; --green:#3ecf72; --blue:#4a9eff; --yellow:#f2c94c;
  --radius:10px; --sidebar-w:264px;
  --font-display:'Oswald',sans-serif; --font-body:'Inter',sans-serif; --font-mono:'JetBrains Mono',monospace;
}
html[data-theme="light"]{
  --bg:#f4f3f0; --bg-elev:#ffffff; --bg-card:#ffffff; --bg-card-hov:#f7f6f3;
  --border:#e2e0da; --border-soft:#ececE7;
  --text:#1a1a1c; --text-dim:#5c5c62; --text-faint:#96969c;
}
*{box-sizing:border-box}
body{
  background:var(--bg); color:var(--text); font-family:var(--font-body);
  margin:0; min-height:100vh; -webkit-font-smoothing:antialiased;
  background-image:
    radial-gradient(circle at 15% 0%, rgba(232,53,47,.06), transparent 40%),
    radial-gradient(circle at 100% 10%, rgba(242,169,60,.05), transparent 35%);
  background-attachment:fixed;
}
h1,h2,h3,h4,h5,.display-font{font-family:var(--font-display); letter-spacing:.02em; text-transform:uppercase;}
.mono{font-family:var(--font-mono)}
a{text-decoration:none}
::-webkit-scrollbar{width:8px;height:8px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:8px}
::-webkit-scrollbar-thumb:hover{background:var(--red-dim)}

/* ============ AUTH ============ */
#authScreen{
  min-height:100vh; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden;
  background:radial-gradient(ellipse at 50% -10%, rgba(232,53,47,.12), transparent 55%), var(--bg);
}
#authScreen::before{
  content:""; position:absolute; inset:0; opacity:.05; pointer-events:none;
  background-image:repeating-linear-gradient(115deg, var(--text) 0 2px, transparent 2px 42px);
}
.auth-card{
  width:100%; max-width:410px; background:var(--bg-card); border:1px solid var(--border);
  border-radius:16px; padding:2.6rem 2.2rem; box-shadow:0 30px 60px -20px rgba(0,0,0,.6);
  position:relative; z-index:2;
}
.auth-logo-wrap{display:flex; flex-direction:column; align-items:center; margin-bottom:1.4rem}
.auth-logo-wrap img{width:88px; height:88px; border-radius:18px; box-shadow:0 0 0 1px var(--border), 0 12px 30px -10px var(--red-glow)}
.brand-title{font-family:var(--font-display); font-weight:700; font-size:1.5rem; letter-spacing:.06em; margin-top:.85rem; text-align:center}
.brand-title span{color:var(--red)}
.brand-tagline{color:var(--text-dim); font-size:.72rem; letter-spacing:.14em; text-transform:uppercase; text-align:center; margin-top:.15rem}
.form-control,.form-select{
  background:var(--bg-elev); border:1px solid var(--border); color:var(--text); border-radius:8px;
  padding:.62rem .85rem; font-size:.9rem;
}
.form-control:focus,.form-select:focus{
  background:var(--bg-elev); color:var(--text); border-color:var(--red); box-shadow:0 0 0 .2rem var(--red-glow);
}
.form-label{font-size:.76rem; text-transform:uppercase; letter-spacing:.08em; color:var(--text-dim); font-weight:600; margin-bottom:.35rem}
.btn-brand{
  background:linear-gradient(135deg,var(--red),var(--red-dim)); border:none; color:#fff; font-weight:600;
  letter-spacing:.04em; text-transform:uppercase; font-size:.82rem; padding:.65rem 1rem; border-radius:8px;
  box-shadow:0 8px 20px -6px var(--red-glow); transition:.2s;
}
.btn-brand:hover{transform:translateY(-1px); box-shadow:0 12px 26px -6px var(--red-glow); color:#fff}
.btn-outline-brand{border:1px solid var(--border); color:var(--text-dim); background:transparent; font-size:.8rem; border-radius:8px}
.btn-outline-brand:hover{border-color:var(--red); color:var(--red)}
.auth-switch{text-align:center; margin-top:1.1rem; font-size:.82rem; color:var(--text-dim)}
.auth-switch a{color:var(--amber); font-weight:600}
.role-pill{
  display:inline-flex; align-items:center; gap:.35rem; border:1px solid var(--border); border-radius:20px;
  padding:.3rem .7rem; font-size:.72rem; color:var(--text-dim); cursor:pointer; transition:.15s;
}
.role-pill.active{border-color:var(--red); color:var(--red); background:var(--red-glow)}

/* ============ APP SHELL ============ */
#appShell{display:none}
.sidebar{
  position:fixed; top:0; left:0; bottom:0; width:var(--sidebar-w); background:var(--bg-elev);
  border-right:1px solid var(--border); display:flex; flex-direction:column; z-index:1030; transition:.25s;
}
.sidebar-brand{
  display:flex; align-items:center; gap:.65rem; padding:1.15rem 1.1rem; border-bottom:1px solid var(--border);
}
.sidebar-brand img{width:42px;height:42px;border-radius:10px; flex-shrink:0}
.sidebar-brand .b-name{font-family:var(--font-display); font-weight:700; font-size:1rem; line-height:1.05; letter-spacing:.03em}
.sidebar-brand .b-name span{color:var(--red)}
.sidebar-brand .b-tag{font-size:.6rem; color:var(--text-faint); letter-spacing:.08em; text-transform:uppercase}
.sidebar-nav{flex:1; overflow-y:auto; padding:.85rem .7rem}
.nav-section-label{font-size:.65rem; text-transform:uppercase; letter-spacing:.12em; color:var(--text-faint); padding:.8rem .6rem .3rem}
.nav-link-item{
  display:flex; align-items:center; gap:.7rem; padding:.55rem .7rem; border-radius:8px; color:var(--text-dim);
  font-size:.86rem; font-weight:500; margin-bottom:.15rem; cursor:pointer; transition:.15s; position:relative;
}
.nav-link-item i{font-size:1rem; width:18px; text-align:center}
.nav-link-item:hover{background:var(--bg-card-hov); color:var(--text)}
.nav-link-item.active{background:linear-gradient(90deg, var(--red-glow), transparent); color:var(--white); }
.nav-link-item.active::before{content:"";position:absolute;left:-.7rem;top:.15rem;bottom:.15rem;width:3px;background:var(--red);border-radius:3px}
.sidebar-foot{padding:.9rem; border-top:1px solid var(--border)}
.main-wrap{margin-left:var(--sidebar-w); min-height:100vh; display:flex; flex-direction:column;}
.topbar{
  position:sticky; top:0; z-index:1020; background:var(--bg-elev); border-bottom:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between; padding:.75rem 1.4rem; gap:1rem;
}
.topbar .search-box{
  flex:1; max-width:380px; position:relative;
}
.topbar .search-box input{padding-left:2.2rem}
.topbar .search-box i{position:absolute; left:.75rem; top:50%; transform:translateY(-50%); color:var(--text-faint)}
.icon-btn{
  width:38px;height:38px; border-radius:9px; background:var(--bg-card); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center; color:var(--text-dim); cursor:pointer; position:relative; transition:.15s;
}
.icon-btn:hover{color:var(--red); border-color:var(--red)}
.badge-dot{position:absolute; top:-4px; right:-4px; background:var(--red); color:#fff; font-size:.6rem; border-radius:10px; padding:.05rem .32rem; font-weight:700}
.user-chip{display:flex; align-items:center; gap:.55rem; cursor:pointer}
.avatar{width:36px;height:36px;border-radius:50%; background:linear-gradient(135deg,var(--red),var(--amber)); display:flex;align-items:center;justify-content:center; font-weight:700; font-size:.85rem; color:#fff}
.page-content{padding:1.5rem 1.6rem 3rem; flex:1}
.page-header{display:flex; align-items:flex-end; justify-content:space-between; flex-wrap:wrap; gap:.8rem; margin-bottom:1.4rem}
.page-title{font-size:1.5rem; margin:0}
.page-subtitle{color:var(--text-dim); font-size:.85rem; margin-top:.15rem; text-transform:none; font-family:var(--font-body); letter-spacing:0}
.breadcrumb-eyebrow{font-size:.68rem; letter-spacing:.16em; text-transform:uppercase; color:var(--red); font-weight:700; margin-bottom:.2rem}

/* Cards */
.card-x{background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); }
.kpi-card{background:var(--bg-card); border:1px solid var(--border); border-radius:14px; padding:1.15rem 1.2rem; display:flex; align-items:center; gap:1rem; position:relative; overflow:hidden; transition:.2s;}
.kpi-card:hover{border-color:var(--red); transform:translateY(-2px)}
.kpi-card .kpi-icon{width:52px;height:52px;border-radius:12px; display:flex;align-items:center;justify-content:center; font-size:1.35rem; flex-shrink:0}
.kpi-card .kpi-val{font-family:var(--font-display); font-size:1.55rem; font-weight:700; line-height:1}
.kpi-card .kpi-label{font-size:.72rem; color:var(--text-dim); text-transform:uppercase; letter-spacing:.06em; margin-top:.25rem}
.kpi-card .kpi-trend{font-size:.72rem; font-weight:600; margin-left:auto; align-self:flex-start}

/* Gauge */
.gauge-wrap{position:relative; width:74px; height:74px; flex-shrink:0}
.gauge-wrap svg{transform:rotate(-90deg)}
.gauge-wrap .gauge-val{position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-family:var(--font-display); font-weight:700; font-size:.95rem}

.section-card{background:var(--bg-card); border:1px solid var(--border); border-radius:14px; padding:1.2rem}
.section-card .section-title{font-size:.95rem; font-weight:700; margin-bottom:.9rem; display:flex; align-items:center; justify-content:between; gap:.5rem}

.table-x{width:100%; border-collapse:separate; border-spacing:0}
.table-x thead th{font-size:.68rem; text-transform:uppercase; letter-spacing:.08em; color:var(--text-faint); border-bottom:1px solid var(--border); padding:.6rem .8rem; text-align:left; font-weight:600}
.table-x tbody td{padding:.65rem .8rem; border-bottom:1px solid var(--border-soft); font-size:.85rem; vertical-align:middle}
.table-x tbody tr{transition:.12s}
.table-x tbody tr:hover{background:var(--bg-card-hov)}
.table-x tbody tr:last-child td{border-bottom:none}

.status-pill{display:inline-flex; align-items:center; gap:.35rem; font-size:.7rem; font-weight:700; padding:.22rem .6rem; border-radius:20px; text-transform:uppercase; letter-spacing:.03em}
.status-pill.dot::before{content:"";width:6px;height:6px;border-radius:50%;background:currentColor}
.s-green{background:rgba(62,207,114,.12); color:var(--green)}
.s-red{background:rgba(232,53,47,.12); color:var(--red)}
.s-amber{background:rgba(242,169,60,.14); color:var(--amber)}
.s-blue{background:rgba(74,158,255,.12); color:var(--blue)}
.s-grey{background:rgba(154,154,160,.12); color:var(--text-dim)}

.btn-icon-sm{width:30px;height:30px;border-radius:7px; border:1px solid var(--border); background:var(--bg-elev); color:var(--text-dim); display:inline-flex; align-items:center; justify-content:center; transition:.15s}
.btn-icon-sm:hover{border-color:var(--red); color:var(--red)}
.btn-icon-sm.danger:hover{border-color:var(--red); background:var(--red-glow); color:var(--red)}

.activity-item{display:flex; gap:.7rem; padding:.6rem 0; border-bottom:1px solid var(--border-soft)}
.activity-item:last-child{border-bottom:none}
.activity-ic{width:34px;height:34px;border-radius:9px; display:flex;align-items:center;justify-content:center; font-size:.85rem; flex-shrink:0}
.activity-text{font-size:.82rem}
.activity-time{font-size:.7rem; color:var(--text-faint)}

.modal-content{background:var(--bg-card); border:1px solid var(--border); color:var(--text)}
.modal-header{border-bottom:1px solid var(--border)}
.modal-footer{border-top:1px solid var(--border)}
.btn-close{filter:invert(1)}
html[data-theme="light"] .btn-close{filter:none}

.nav-tabs-x{display:flex; gap:.3rem; border-bottom:1px solid var(--border); margin-bottom:1.2rem; flex-wrap:wrap}
.nav-tabs-x .tb{padding:.5rem .95rem; font-size:.82rem; font-weight:600; color:var(--text-dim); cursor:pointer; border-bottom:2px solid transparent}
.nav-tabs-x .tb.active{color:var(--red); border-color:var(--red)}

.empty-state{text-align:center; padding:2.6rem 1rem; color:var(--text-dim)}
.empty-state i{font-size:2.2rem; color:var(--text-faint); margin-bottom:.6rem; display:block}

.sidebar-collapsed .sidebar{width:78px}
.sidebar-collapsed .main-wrap{margin-left:78px}
.sidebar-collapsed .sidebar-brand .b-name,.sidebar-collapsed .sidebar-brand .b-tag,.sidebar-collapsed .nav-link-item span{display:none}
.sidebar-collapsed .nav-section-label{display:none}

@media(max-width:991px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.mobile-open{transform:translateX(0)}
  .main-wrap{margin-left:0}
  .sidebar-collapsed .main-wrap{margin-left:0}
}
.overlay-bg{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1025;display:none}
.overlay-bg.show{display:block}

.badge-role{font-size:.62rem; text-transform:uppercase; letter-spacing:.05em; padding:.15rem .5rem; border-radius:5px; font-weight:700}

.form-check-input:checked{background-color:var(--red); border-color:var(--red)}
.form-switch .form-check-input{background-color:var(--bg-elev); border-color:var(--border)}

.toast-x{position:fixed; bottom:1.2rem; right:1.2rem; z-index:2000; background:var(--bg-card); border:1px solid var(--border); border-left:3px solid var(--green); border-radius:8px; padding:.8rem 1.1rem; font-size:.85rem; box-shadow:0 12px 30px -10px rgba(0,0,0,.5); display:flex; align-items:center; gap:.6rem; min-width:240px; transform:translateY(20px); opacity:0; transition:.25s;}
.toast-x.show{transform:translateY(0); opacity:1}

.print-invoice{display:none}
@media print{
  body *{visibility:hidden}
  .print-invoice, .print-invoice *{visibility:visible}
  .print-invoice{display:block; position:absolute; top:0; left:0; width:100%}
}
</style>
</head>
<body>

<!-- ============ AUTH SCREEN ============ -->
<div id="authScreen">
  <div class="auth-card" id="authCard">
    <div class="auth-logo-wrap">
      <img src="data:image/png;base64," alt="Auto Check Pro AL">
      <div class="brand-title">AUTO CHECK <span>PRO</span> AL</div>
      <div class="brand-tagline" id="authTagline">Advanced Vehicle Diagnostics &amp; Workshop Management</div>
    </div>
    <div id="authFormArea"></div>
  </div>
</div>

<!-- ============ APP SHELL ============ -->
<div id="appShell">
  <div class="overlay-bg" id="overlayBg" onclick="toggleMobileSidebar(false)"></div>
  <aside class="sidebar" id="sidebarEl">
    <div class="sidebar-brand">
      <img src="data:image/png;base64," alt="logo">
      <div>
        <div class="b-name">AUTO CHECK <span>PRO</span> AL</div>
        <div class="b-tag" data-i18n="tagline_short">Workshop Management</div>
      </div>
    </div>
    <nav class="sidebar-nav" id="sidebarNav"></nav>
    <div class="sidebar-foot">
      <button class="btn btn-outline-brand w-100 btn-sm" onclick="logout()"><i class="bi bi-box-arrow-left me-1"></i> <span data-i18n="logout">Log Out</span></button>
    </div>
  </aside>

  <div class="main-wrap">
    <div class="topbar">
      <div class="d-flex align-items-center gap-2">
        <div class="icon-btn d-lg-none" onclick="toggleMobileSidebar(true)"><i class="bi bi-list"></i></div>
        <div class="icon-btn d-none d-lg-flex" onclick="toggleSidebarCollapse()"><i class="bi bi-layout-sidebar"></i></div>
        <div class="search-box d-none d-md-block">
          <i class="bi bi-search"></i>
          <input type="text" class="form-control form-control-sm" id="globalSearch" placeholder="Search customers, vehicles, invoices…" oninput="globalSearchHandler(this.value)">
          <div id="globalSearchResults"></div>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2">
        <div class="icon-btn" onclick="toggleLang()" title="EN / SQ"><span class="mono fw-bold" style="font-size:.7rem" id="langBtnLabel">EN</span></div>
        <div class="icon-btn" onclick="toggleTheme()"><i class="bi bi-moon-stars" id="themeIcon"></i></div>
        <div class="icon-btn" onclick="showPage('notifications')">
          <i class="bi bi-bell"></i>
          <span class="badge-dot" id="notifCount">0</span>
        </div>
        <div class="user-chip dropdown">
          <div class="avatar" id="userAvatar">A</div>
          <div class="d-none d-md-block">
            <div style="font-size:.8rem;font-weight:600" id="userNameLabel">Admin</div>
            <div style="font-size:.68rem;color:var(--text-dim)" id="userRoleLabel">Administrator</div>
          </div>
        </div>
      </div>
    </div>
    <div class="page-content" id="pageContent"></div>
  </div>
</div>

<div class="toast-x" id="toastX"><i class="bi bi-check-circle-fill" style="color:var(--green)"></i><span id="toastMsg">Saved</span></div>
<div id="printArea" class="print-invoice"></div>

<script>
/* =========================================================================
   AUTO CHECK PRO AL — Workshop Management SPA
   Single-file client app: vanilla JS + Bootstrap 5 + localStorage "database"
   ========================================================================= */

/* ---------------- i18n ---------------- */
const I18N = {
  en:{
    tagline_short:"Workshop Management", logout:"Log Out",
    nav_dashboard:"Dashboard", nav_customers:"Customers", nav_vehicles:"Vehicles",
    nav_diagnostics:"Diagnostics", nav_workorders:"Work Orders", nav_appointments:"Appointments",
    nav_inventory:"Inventory", nav_invoices:"Invoices", nav_payments:"Payments",
    nav_reports:"Reports", nav_staff:"Staff", nav_settings:"Settings",
    section_main:"Main", section_operations:"Operations", section_business:"Business", section_admin:"Admin",
    login:"Log In", register:"Create Account", forgot:"Forgot Password",
    email:"Email", password:"Password", full_name:"Full Name", confirm_password:"Confirm Password",
    welcome_back:"Welcome back", sign_in_sub:"Sign in to manage your workshop",
    no_account:"Don't have an account?", have_account:"Already have an account?",
    create_account:"Create Account", back_to_login:"Back to log in",
    forgot_sub:"Enter your email and we'll send reset instructions",
    send_reset:"Send Reset Link", reset_sent:"If that account exists, a reset link was sent.",
    add:"Add", edit:"Edit", delete:"Delete", save:"Save", cancel:"Cancel", search:"Search…",
    actions:"Actions", status:"Status", close:"Close",
  },
  sq:{
    tagline_short:"Menaxhim Servisi", logout:"Dilni",
    nav_dashboard:"Paneli", nav_customers:"Klientët", nav_vehicles:"Automjetet",
    nav_diagnostics:"Diagnostikimi", nav_workorders:"Urdhërat e Punës", nav_appointments:"Termine",
    nav_inventory:"Inventari", nav_invoices:"Faturat", nav_payments:"Pagesat",
    nav_reports:"Raportet", nav_staff:"Stafi", nav_settings:"Cilësimet",
    section_main:"Kryesore", section_operations:"Operacione", section_business:"Biznesi", section_admin:"Administrim",
    login:"Hyr", register:"Krijo Llogari", forgot:"Keni harruar fjalëkalimin",
    email:"Email", password:"Fjalëkalimi", full_name:"Emri i Plotë", confirm_password:"Konfirmo Fjalëkalimin",
    welcome_back:"Mirë se erdhe", sign_in_sub:"Hyni për të menaxhuar servisin tuaj",
    no_account:"Nuk keni llogari?", have_account:"Keni tashmë një llogari?",
    create_account:"Krijo Llogari", back_to_login:"Kthehu te hyrja",
    forgot_sub:"Shkruani email-in dhe ne do dërgojmë udhëzimet",
    send_reset:"Dërgo Linkun", reset_sent:"Nëse llogaria ekziston, linku u dërgua.",
    add:"Shto", edit:"Ndrysho", delete:"Fshi", save:"Ruaj", cancel:"Anulo", search:"Kërko…",
    actions:"Veprime", status:"Statusi", close:"Mbyll",
  }
};
let currentLang = localStorage.getItem('acp_lang') || 'en';
function t(key){ return (I18N[currentLang] && I18N[currentLang][key]) || (I18N.en[key]) || key; }
function applyI18n(){
  document.querySelectorAll('[data-i18n]').forEach(el=>{
    const k = el.getAttribute('data-i18n');
    el.textContent = t(k);
  });
  document.querySelectorAll('[data-i18n-ph]').forEach(el=>{
    el.setAttribute('placeholder', t(el.getAttribute('data-i18n-ph')));
  });
  document.getElementById('langBtnLabel').textContent = currentLang.toUpperCase();
}
function toggleLang(){
  currentLang = currentLang === 'en' ? 'sq' : 'en';
  localStorage.setItem('acp_lang', currentLang);
  applyI18n();
  renderAuthForm(authMode);
  if(document.getElementById('appShell').style.display !== 'none'){ renderSidebar(); router(); }
}

/* ---------------- Theme ---------------- */
function toggleTheme(){
  const html = document.documentElement;
  const cur = html.getAttribute('data-theme');
  const next = cur === 'dark' ? 'light' : 'dark';
  html.setAttribute('data-theme', next);
  localStorage.setItem('acp_theme', next);
  document.getElementById('themeIcon').className = next === 'dark' ? 'bi bi-moon-stars' : 'bi bi-sun';
}
(function initTheme(){
  const saved = localStorage.getItem('acp_theme') || 'dark';
  document.documentElement.setAttribute('data-theme', saved);
})();

/* ---------------- DB helpers (localStorage) ---------------- */
const DB_KEY = 'acp_db_v1';
function loadDB(){
  let raw = localStorage.getItem(DB_KEY);
  if(!raw){ seedDB(); raw = localStorage.getItem(DB_KEY); }
  return JSON.parse(raw);
}
function saveDB(db){ localStorage.setItem(DB_KEY, JSON.stringify(db)); }
