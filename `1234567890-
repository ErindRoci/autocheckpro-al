function runScan(){
  const vehicleId = document.getElementById('diagVehicleSelect').value;
  const numFaults = Math.random() > 0.4 ? Math.floor(Math.random()*3)+1 : 0;
  const shuffled = [...DTC_DB].sort(()=>0.5-Math.random());
  const codes = shuffled.slice(0,numFaults);
  const box = document.getElementById('scanResult');
