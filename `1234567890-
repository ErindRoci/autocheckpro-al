function hasAccess(key){
  if(!currentUser) return false;
  const perms = ROLE_PERMISSIONS[currentUser.role];
  return perms === null || perms.includes(key);
}
function renderSidebar(){
  const nav = document.getElementById('sidebarNav');
  let html = '';
  NAV_ITEMS.forEach(sec=>{
    const visible = sec.items.filter(it=>hasAccess(it.key));
    if(!visible.length) return;
    html += `<div class="nav-section-label" data-i18n="${sec.section}">${t(sec.section)}</div>`;
    visible.forEach(it=>{
      html += `<div class="nav-link-item" data-page="${it.key}" onclick="showPage('${it.key}')"><i class="bi ${it.icon}"></i><span data-i18n="${it.label}">${t(it.label)}</span></div>`;
    });
  });
  nav.innerHTML = html;
}
let currentPage = 'dashboard';
function showPage(key){
  if(!hasAccess(key)){ showToast('You do not have access to this section.','error'); return; }
  location.hash = key;
  toggleMobileSidebar(false);
}
window.addEventListener('hashchange', router);
function router(){
  let page = (location.hash||'#dashboard').slice(1) || 'dashboard';
  if(!hasAccess(page)) page = 'dashboard';
  currentPage = page;
  document.querySelectorAll('.nav-link-item').forEach(el=>{
    el.classList.toggle('active', el.getAttribute('data-page')===page);
  });
  const renderFn = window['render_'+page];
  if(typeof renderFn === 'function') renderFn();
  else document.getElementById('pageContent').innerHTML = `<div class="empty-state"><i class="bi bi-cone-striped"></i>Page not found.</div>`;
}
