/* ---------------- Toast ---------------- */
function showToast(msg, type){
  const el = document.getElementById('toastX');
  document.getElementById('toastMsg').textContent = msg;
  el.style.borderLeftColor = type==='error' ? 'var(--red)' : 'var(--green)';
  el.querySelector('i').style.color = type==='error' ? 'var(--red)' : 'var(--green)';
  el.querySelector('i').className = type==='error' ? 'bi bi-x-circle-fill' : 'bi bi-check-circle-fill';
  el.classList.add('show');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=>el.classList.remove('show'), 2600);
}

