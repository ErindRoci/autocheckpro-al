/* ================= REPORTS ================= */
function render_reports(){
  const db = loadDB();
  document.getElementById('pageContent').innerHTML = `
    <div class="page-header"><div><div class="breadcrumb-eyebrow">${t('nav_reports')}</div><h1 class="page-title">${t('nav_reports')}</h1>
    <div class="page-subtitle">Revenue trends, common repairs, customer & technician performance.</div></div>
    <div class="d-flex gap-2">
      <button class="btn btn-outline-brand btn-sm" onclick="exportReportCSV()"><i class="bi bi-file-earmark-spreadsheet me-1"></i>Export Excel (CSV)</button>
      <button class="btn btn-outline-brand btn-sm" onclick="window.print()"><i class="bi bi-file-earmark-pdf me-1"></i>Export PDF</button>
    </div></div>
    <div class="row g-3">
      <div class="col-lg-6"><div class="section-card"><div class="section-title">Daily Revenue (14 days)</div><canvas id="repDaily" height="180"></canvas></div></div>
      <div class="col-lg-6"><div class="section-card"><div class="section-title">Monthly Revenue (6 months)</div><canvas id="repMonthly" height="180"></canvas></div></div>
      <div class="col-lg-6"><div class="section-card"><div class="section-title">Most Common Repairs</div><canvas id="repRepairs" height="180"></canvas></div></div>
      <div class="col-lg-6"><div class="section-card"><div class="section-title">Technician Performance</div><canvas id="repTech" height="180"></canvas></div></div>
      <div class="col-12"><div class="section-card"><div class="section-title">Customer Statistics</div>
        <div class="table-responsive"><table class="table-x"><thead><tr><th>Customer</th><th>Vehicles</th><th>Jobs</th><th>Total Spent</th></tr></thead>
        <tbody id="custStatsTbody"></tbody></table></div>
      </div></div>
    </div>`;

  const invAmt = (inv)=> invoiceAmounts(inv).total;
  const days = [...Array(14)].map((_,i)=>{ const d=new Date(); d.setDate(d.getDate()-(13-i)); return d.toISOString().slice(0,10); });
  const dailyData = days.map(d=> db.invoices.filter(i=>i.date===d).reduce((s,i)=>s+invAmt(i),0));
  new Chart(document.getElementById('repDaily'), {type:'bar', data:{labels:days.map(d=>d.slice(8)), datasets:[{label:'Revenue',data:dailyData,backgroundColor:'#e8352f'}]},
    options:{plugins:{legend:{display:false}}, scales:{x:{ticks:{color:'#9a9aa0'},grid:{display:false}},y:{ticks:{color:'#9a9aa0'},grid:{color:'rgba(255,255,255,.05)'}}}}});

  const months = [...Array(6)].map((_,i)=>{ const d=new Date(); d.setMonth(d.getMonth()-(5-i)); return d.toISOString().slice(0,7); });
  const monthlyData = months.map(m=> db.invoices.filter(i=>i.date.slice(0,7)===m).reduce((s,i)=>s+invAmt(i),0));
  new Chart(document.getElementById('repMonthly'), {type:'line', data:{labels:months, datasets:[{label:'Revenue',data:monthlyData,borderColor:'#f2a93c',backgroundColor:'rgba(242,169,60,.15)',fill:true,tension:.3}]},
    options:{plugins:{legend:{display:false}}, scales:{x:{ticks:{color:'#9a9aa0'},grid:{display:false}},y:{ticks:{color:'#9a9aa0'},grid:{color:'rgba(255,255,255,.05)'}}}}});

  const repairCounts = {};
  db.workorders.forEach(w=>{ repairCounts[w.description] = (repairCounts[w.description]||0)+1; });
  const repEntries = Object.entries(repairCounts).sort((a,b)=>b[1]-a[1]).slice(0,6);
  new Chart(document.getElementById('repRepairs'), {type:'bar', data:{labels:repEntries.map(e=>e[0]), datasets:[{label:'Jobs',data:repEntries.map(e=>e[1]),backgroundColor:'#4a9eff'}]},
    options:{indexAxis:'y', plugins:{legend:{display:false}}, scales:{x:{ticks:{color:'#9a9aa0'},grid:{color:'rgba(255,255,255,.05)'}},y:{ticks:{color:'#9a9aa0'},grid:{display:false}}}}});

  const techCounts = {};
  db.workorders.forEach(w=>{ if(!w.technician) return; techCounts[w.technician] = techCounts[w.technician]||{jobs:0,revenue:0}; techCounts[w.technician].jobs++; techCounts[w.technician].revenue += woTotal(w); });
  const techEntries = Object.entries(techCounts);
  new Chart(document.getElementById('repTech'), {type:'doughnut', data:{labels:techEntries.map(e=>e[0]), datasets:[{data:techEntries.map(e=>e[1].jobs),backgroundColor:['#e8352f','#f2a93c','#4a9eff','#3ecf72','#9a9aa0']}]},
    options:{plugins:{legend:{position:'bottom',labels:{color:'#9a9aa0'}}}}});

  document.getElementById('custStatsTbody').innerHTML = db.customers.map(c=>{
    const vcount = db.vehicles.filter(v=>v.customerId===c.id).length;
    const jobs = db.workorders.filter(w=>w.customerId===c.id);
    const spent = db.invoices.filter(i=>i.customerId===c.id).reduce((s,i)=>s+invAmt(i),0);
    return `<tr><td>${esc(c.name)}</td><td>${vcount}</td><td>${jobs.length}</td><td>${fmtMoney(spent)}</td></tr>`;
  }).join('');
}
function exportReportCSV(){
  const db = loadDB();
  let csv = 'Customer,Vehicles,Jobs,Total Spent\n';
  db.customers.forEach(c=>{
    const vcount = db.vehicles.filter(v=>v.customerId===c.id).length;
    const jobs = db.workorders.filter(w=>w.customerId===c.id).length;
    const spent = db.invoices.filter(i=>i.customerId===c.id).reduce((s,i)=>s+invoiceAmounts(i).total,0);
    csv += `"${c.name}",${vcount},${jobs},${spent.toFixed(2)}\n`;
  });
  const blob = new Blob([csv], {type:'text/csv'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'AutoCheckPro_Report.csv'; a.click();
  showToast('Report exported as CSV.');
}

