function ensureModalRoot(){
  if(document.getElementById('genModal')) return;
  const div = document.createElement('div');
  div.innerHTML = `
  <div class="modal fade" id="genModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h6 class="modal-title mb-0" id="genModalTitle"></h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" id="genModalBody"></div>
        <div class="modal-footer">
          <button class="btn btn-outline-brand btn-sm" data-bs-dismiss="modal">${t('cancel')}</button>
          <button class="btn btn-brand btn-sm" id="genModalSave">${t('save')}</button>
        </div>
      </div>
    </div>
  </div>`;
  document.body.appendChild(div.firstElementChild);
}
function fieldHtml(f, val){
  val = val==null?'':val;
  if(f.type==='select'){
    return `<div class="mb-2"><label class="form-label">${f.label}</label>
      <select class="form-select form-select-sm" id="f_${f.key}">
        ${f.options.map(o=>`<option value="${o.value}" ${o.value===val?'selected':''}>${o.label}</option>`).join('')}
      </select></div>`;
  }
  if(f.type==='textarea'){
    return `<div class="mb-2"><label class="form-label">${f.label}</label><textarea class="form-control form-control-sm" id="f_${f.key}" rows="2">${esc(val)}</textarea></div>`;
  }
  return `<div class="mb-2"><label class="form-label">${f.label}</label><input type="${f.type||'text'}" class="form-control form-control-sm" id="f_${f.key}" value="${esc(val)}"></div>`;
}
function openFormModal(title, fields, data, onSave){
  ensureModalRoot();
  document.getElementById('genModalTitle').textContent = title;
  document.getElementById('genModalBody').innerHTML = fields.map(f=>fieldHtml(f, data?data[f.key]:f.default)).join('');
  const modalEl = document.getElementById('genModal');
  const modal = new bootstrap.Modal(modalEl);
  document.getElementById('genModalSave').onclick = ()=>{
    const result = {};
    let valid = true;
    fields.forEach(f=>{
      const el = document.getElementById('f_'+f.key);
      result[f.key] = el.value;
      if(f.required && !el.value.trim()){ valid=false; el.classList.add('is-invalid'); } else el.classList.remove('is-invalid');
    });
    if(!valid){ showToast('Please fill required fields.','error'); return; }
    onSave(result);
    modal.hide();
  };
  modal.show();
}
function confirmDelete(msg, onYes){
  ensureModalRoot();
  document.getElementById('genModalTitle').textContent = 'Confirm Delete';
  document.getElementById('genModalBody').innerHTML = `<p style="font-size:.88rem" class="mb-0"><i class="bi bi-exclamation-triangle text-danger me-2"></i>${msg}</p>`;
  const modalEl = document.getElementById('genModal');
  const modal = new bootstrap.Modal(modalEl);
  const saveBtn = document.getElementById('genModalSave');
  saveBtn.textContent = t('delete'); saveBtn.classList.add('btn-danger');
  saveBtn.onclick = ()=>{ onYes(); modal.hide(); saveBtn.textContent=t('save'); saveBtn.classList.remove('btn-danger'); };
  modal.show();
}

